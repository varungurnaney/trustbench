  "non_compliant_streams": [
    {
      "stream": "claims-adjudication-engine-logs",
      "category": "Application + Audit (mixed)",
      "required_retention": "7 years (contains audit data)",
      "actual_retention": "90 days",
      "storage_tier": "Hot: 90d only — no warm or cold configured",
      "status": "Non-Compliant",
      "details": "The claims adjudication engine (deployed March 2025) writes a single combined log stream containing both application diagnostic logs and adjudication decision audit records (claim decisions, approval/denial rationale, adjuster actions, override justifications). The Splunk index for this stream has a 90-day retention lifecycle policy — the default for 'Application' category logs. However, the stream contains audit records of claims adjudication decisions which are regulatory records requiring 7-year retention. No S3 cold storage archive is configured for this stream. The infrastructure team classified this stream as 'Application' during onboarding, missing the embedded audit data. No exception exists in the exception register.",
      "data_at_risk": "Claims adjudication decisions including: claim approval/denial with rationale, adjuster override actions with justification, automated decision model outputs, and policyholder dispute resolution records. Approximately 4,200 adjudication decisions per day.",
      "regulatory_impact": "State insurance regulations require 7-year retention of claims adjudication records. SOX requires 7-year retention of financial decision audit trails. Loss of these records could result in regulatory penalties during state examinations."
    }
  ],
  "informational_items": [
    {
      "stream": "document-ocr-processing-logs",

{
  "pipeline_metadata": {
    "pipeline_name": "prism-data-masking-pipeline",
    "version": "2.4.1",
    "last_updated": "2025-09-15",
    "owner": "IT Security Team",
    "schedule": "Weekly — Sundays 02:00 AM EST"
  },
  "source_database": {
    "host": "prism-prod-rds.cluster-abc123.us-east-1.rds.amazonaws.com",
    "database": "prism_production",
    "type": "PostgreSQL 15.4"
  },
  "target_database": {
    "host": "prism-staging-rds.cluster-xyz789.us-east-1.rds.amazonaws.com",
    "database": "prism_staging",
    "type": "PostgreSQL 15.4"
  },
  "masking_rules": [
    {
      "field_name": "ssn",
      "masking_method": "format_preserving_encryption",
      "key_reference": "aws-kms:alias/prism-masking-key",
      "output_format": "###-##-####",
      "applies_to_datasets": ["DS-STG-001", "DS-STG-002", "DS-STG-003", "DS-STG-004", "DS-STG-005"]
    },
    {
      "field_name": "credit_card_number",
      "masking_method": "tokenization",
      "token_vault": "aws-dynamodb:prism-token-vault",
      "output_format": "tok_################",
      "applies_to_datasets": ["DS-STG-001", "DS-STG-003", "DS-STG-005"]
    },
    {
      "field_name": "phone_number",
      "masking_method": "partial_redaction",
      "redaction_pattern": "***-***-####",
      "preserve_last_n": 4,
      "applies_to_datasets": ["DS-STG-001", "DS-STG-002", "DS-STG-003", "DS-STG-004", "DS-STG-005"]
    },
    {
      "field_name": "date_of_birth",
      "masking_method": "generalization",
      "generalization_level": "year_only",
      "output_format": "YYYY-01-01",
      "applies_to_datasets": ["DS-STG-001", "DS-STG-002", "DS-STG-003", "DS-STG-004", "DS-STG-005"]
    },
    {
      "field_name": "full_name",
      "masking_method": "synthetic_replacement",
      "synthetic_source": "prism-syngen-v2.1",
      "locale": "en_US",
      "applies_to_datasets": ["DS-STG-001", "DS-STG-002", "DS-STG-003", "DS-STG-004", "DS-STG-005"]
    },
    {
      "field_name": "physical_address",
      "masking_method": "generalization",
      "generalization_level": "city_state_only",
      "applies_to_datasets": ["DS-STG-001", "DS-STG-002", "DS-STG-004"]
    }
  ],
  "excluded_datasets": [
    {
      "dataset_id": "DS-STG-006",
      "reason": "Fully synthetic data generated by SynGen — no production data",
      "masking_enabled": false
    },
    {
      "dataset_id": "DS-STG-007",
      "reason": "QA team requires realistic data for integration testing — classified as test data per QA lead approval (Jamie Morrison, QA Lead, approved 2025-06-15)",
      "masking_enabled": false,
      "source": "Production Clone",
      "record_count": 47000,
      "refresh_schedule": "Weekly — same as masking pipeline",
      "contains_fields": ["customer_id", "full_name", "email_address", "phone_number", "ssn", "date_of_birth", "physical_address", "account_status", "signup_date", "subscription_tier"]
    }
  ],
  "validation": {
    "last_validation_date": "2025-10-15",
    "validation_method": "100-record sample per dataset",
    "validation_result": "PASS — all sampled records in DS-STG-001 through DS-STG-005 confirmed masked",
    "validator": "IT Security — Automated Validation Script v1.2",
    "notes": "DS-STG-006 and DS-STG-007 excluded from validation scope — DS-STG-006 is synthetic, DS-STG-007 classified as test data"
  }
}